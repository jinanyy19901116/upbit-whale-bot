# Telegram
TELEGRAM_BOT_TOKEN=你的telegram_bot_token
TELEGRAM_CHAT_ID=你的chat_id

# 监控币种，逗号分隔
# 只监控同时存在 Upbit KRW 现货 和 Binance USDT 永续/期货价格的币种
SYMBOLS=XRPUSDT,ANKRUSDT,CHZUSDT,XLMUSDT,STEEMUSDT,SUIUSDT,WLDUSDT,KITEUSDT,SEIUSDT,AKTUSDT,CPOOLUSDT,TRUMPUSDT,ANIMEUSDT

# 循环间隔（秒）
LOOP_SECONDS=20

# 触发条件（保留这些变量，机器人会根据它们生成做多/做空信号）
PREMIUM_THRESHOLD_PCT=2.0
PREMIUM_CHANGE_THRESHOLD_PCT=0.5
UPBIT_LEAD_THRESHOLD_PCT=1.2
VOLUME_SPIKE_RATIO=2.0

# 单个币种同方向告警冷却时间（秒）
COOLDOWN_SECONDS=900

# Upbit 1分钟K线回看数量
CANDLE_COUNT=20

LOG_LEVEL=INFO
